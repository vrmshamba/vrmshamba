{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# List all your task functions here\ntasks_to_run = [\n    a01_elder_circle, a02_unannounced_elder, a03_correcting_elder,\n    b01_funeral_arrival, b02_colleague_bereavement, b03_funeral_food,\n    c01_family_loan_decline, c02_debt_recovery, c03_chama_late_contributions,\n    d01_official_seating, d02_redirecting_colleague, d03_silence_after_promotion\n]\n\n# Run them one by one\nfor task in tasks_to_run:\n    try:\n        print(f\"Running {task.name}...\")\n        task.run(kbench.llm)\n    except Exception as e:\n        print(f\"Error in {task.name}: {e}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T03:59:40.915489Z","iopub.execute_input":"2026-04-16T03:59:40.916108Z","iopub.status.idle":"2026-04-16T04:01:25.432359Z","shell.execute_reply.started":"2026-04-16T03:59:40.916072Z","shell.execute_reply":"2026-04-16T04:01:25.431168Z"}},"outputs":[{"name":"stdout","text":"Running A-01: Speaking Up in an Elder Circle...\nRunning A-02: Receiving an Unannounced Elder Visitor...\nRunning A-03: Correcting an Elder's Factual Error...\nRunning B-01: Arriving at a Funeral Home...\nRunning B-02: Responding to a Colleague's Bereavement...\nRunning B-03: Accepting Food at a Funeral...\nRunning C-01: Declining a Family Loan Request...\nRunning C-02: Recovering a Debt from a Friend...\nRunning C-03: Addressing Late Contributions in a Chama...\nRunning D-01: Senior Official at a Traditional Gathering...\nRunning D-02: Husband Redirecting an Exclusionary Colleague...\nRunning D-03: Reading Silence After a Promotion Announcement...\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"import kaggle_benchmarks as kbench\n \n# ============================================================\n# KenSoc-Eval: Cultural Social Cognition Benchmark\n# Author: Susan Ngatia / Mediatec.Africa\n# Track: Social Cognition\n# Hackathon: DeepMind / Kaggle AGI Hackathon 2026\n# ============================================================\n \n \n# -------------------------------------------------------\n# DOMAIN A: ELDER HIERARCHY\n# -------------------------------------------------------\n \n@kbench.task(\n    name=\"A-01: Speaking Up in an Elder Circle\",\n    description=\"Tests whether a model understands that in many Kenyan family contexts, a young person does not speak unsolicited in an elder discussion, even when they hold relevant information. The correct move is to route information through a trusted elder as a proxy.\"\n)\ndef a01_elder_circle(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA young professional in their late twenties arrives at a family gathering. Several elders are already seated in a discussion circle debating a land matter that directly affects the younger person's family. The young person has important legal information that could change the outcome. Nobody has addressed them yet.\n \nQuestion: What is the most appropriate action for the young professional to take?\n \nOptions:\nA: Speak up immediately and share the legal information with the group, since the information is urgent and relevant.\nB: Wait to be addressed. In the meantime, quietly pass the information to a trusted elder nearby who can relay it appropriately to the circle.\nC: Write the key points on a piece of paper and discreetly slide it to the elder leading the discussion.\nD: Bow respectfully toward the circle to signal a wish to speak, then wait for acknowledgment before addressing the group.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer recognizes that a young person should not speak unsolicited in an elder circle, and that routing information through a trusted elder is the culturally appropriate mechanism.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \na01_elder_circle.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"A-02: Receiving an Unannounced Elder Visitor\",\n    description=\"Tests whether a model understands that an elder's unannounced visit must be received with full enthusiasm regardless of the inconvenience. Work deadlines are socially irrelevant until the elder is settled and comfortable.\"\n)\ndef a02_unannounced_elder(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nAn elderly woman visits her nephew's home unannounced on a weekday afternoon. The nephew and his wife are both working from home on urgent deadlines. The wife answers the door.\n \nQuestion: What is the most appropriate response from the wife?\n \nOptions:\nA: Politely explain that both she and her husband are currently working and ask if the aunt can return at a more convenient time.\nB: Welcome her warmly, quickly offer a seat near the door, and call her husband to come receive his aunt while she returns to her work.\nC: Welcome her with full enthusiasm, bring her inside, offer refreshments, make her completely comfortable, and only then let her husband know, without mentioning the deadlines at all.\nD: Call her husband to the door immediately so he can properly receive his own aunt.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"c\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be C.\",\n            \"The correct answer prioritizes the elder's comfort completely before any logistics, and does not signal that she is an interruption.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \na02_unannounced_elder.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"A-03: Correcting an Elder's Factual Error\",\n    description=\"Tests whether a model understands the indirect correction technique used in Kenyan social contexts. A younger expert must introduce correct information without publicly confronting or embarrassing an elder. Attributed knowledge is the tool.\"\n)\ndef a03_correcting_elder(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nDuring a family discussion, a 70-year-old grandfather makes a factual claim that a 35-year-old family member, a trained engineer, knows to be incorrect. The error could lead to a poor decision about a construction project.\n \nQuestion: How should the engineer most appropriately handle this?\n \nOptions:\nA: Respectfully but directly correct the grandfather by explaining the engineering principle and why his claim is inaccurate.\nB: Reference external knowledge indirectly, for example by saying 'I recall reading that engineers typically recommend...' to introduce the correct information without confronting him.\nC: Stay silent during the meeting to avoid embarrassing him, then speak privately to another family member afterward.\nD: Ask a fellow elder in the room to raise the engineering question on the engineer's behalf.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer uses indirect, attributed knowledge to introduce correct information without directly confronting or embarrassing the elder.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \na03_correcting_elder.run(kbench.llm)\n \n \n# -------------------------------------------------------\n# DOMAIN B: GRIEF CONDUCT\n# -------------------------------------------------------\n \n@kbench.task(\n    name=\"B-01: Arriving at a Funeral Home\",\n    description=\"Tests action sequencing at a Kenyan funeral reception. The correct behavior follows the social choreography: acknowledge the family member at the gate, follow their lead, and wait before approaching the immediate family. Direct access to the widow is a social failure.\"\n)\ndef b01_funeral_arrival(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nYou arrive at the home of a family who lost their father three days ago. Several neighbors are already seated outside. The widow is visible through the doorway. Someone from the family approaches you at the gate to receive you.\n \nQuestion: What do you say and do first?\n \nOptions:\nA: Walk in confidently, go directly to the widow, hold her hands, and offer your condolences in full.\nB: Offer a brief 'Pole sana' to the family member at the gate, follow their lead on where to sit, greet those seated quietly, and wait before approaching the immediate family.\nC: Ask the family member at the gate whether now is a good time to offer condolences to the widow.\nD: Say nothing, bow your head respectfully, and find a seat among the other guests.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer follows the social choreography: acknowledge the family member at the gate first, follow their direction, and wait to approach the widow until the family indicates it is appropriate.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nb01_funeral_arrival.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"B-02: Responding to a Colleague's Bereavement\",\n    description=\"Tests whether a model understands Kenyan workplace grief conduct. The correct response combines verbal acknowledgment, a physical or financial commitment signal, and social normalcy. Western HR defaults around therapy and time-off miss the communal obligation dimension.\"\n)\ndef b02_colleague_bereavement(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA close colleague tells you on Monday morning that their mother passed away over the weekend. You were not close to the mother. You want to support your colleague.\n \nQuestion: What is the most appropriate response in a Kenyan workplace context?\n \nOptions:\nA: Say 'Pole sana', ask about the burial arrangements, offer to attend or contribute toward funeral costs, and then treat them as normally as the day allows.\nB: Offer an extended expression of sympathy and encourage them to take time off work if they need it.\nC: Post a condolence message on their social media so others can also show support.\nD: Suggest they speak to HR about bereavement leave and check in with them regularly throughout the week.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"a\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be A.\",\n            \"The correct answer combines the verbal acknowledgment 'pole sana', a commitment to show up physically or financially, and social restraint in the workplace.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nb02_colleague_bereavement.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"B-03: Accepting Food at a Funeral\",\n    description=\"Tests whether a model understands that food at a Kenyan funeral carries communal meaning beyond nutrition. Refusing or negotiating food is socially disruptive. Accepting it is an act of solidarity with the grieving family.\"\n)\ndef b03_funeral_food(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nYou are at a funeral gathering and food is being served to guests. You are not particularly hungry. The woman serving you insists you take a full plate.\n \nQuestion: What is the appropriate response?\n \nOptions:\nA: Politely decline and explain that you are not hungry but thank her for the offer.\nB: Accept a smaller portion and thank her, explaining you will not be able to finish a full plate.\nC: Accept the full plate graciously and eat what you can.\nD: Accept it and discreetly pass part of the food to someone seated nearby.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"c\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be C.\",\n            \"The correct answer recognizes that food at a Kenyan funeral is an act of communal solidarity. Accepting it fully honors the family's hospitality regardless of personal hunger.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nb03_funeral_food.run(kbench.llm)\n \n \n# -------------------------------------------------------\n# DOMAIN C: MONEY AND DEBT\n# -------------------------------------------------------\n \n@kbench.task(\n    name=\"C-01: Declining a Family Loan Request\",\n    description=\"Tests whether a model understands the face-saving exit available in Kenyan family financial contexts. The 'I also have difficulties' framing preserves dignity for both parties without direct accusation or false promise.\"\n)\ndef c01_family_loan_decline(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA close relative calls to ask for a significant loan. You do not have the money available right now. You also suspect they will not repay it easily based on past experience.\n \nQuestion: What is the most socially appropriate response in a Kenyan family context?\n \nOptions:\nA: Be honest and explain that you cannot lend to people who have not repaid you before, citing past experience.\nB: Express genuine sympathy, explain that you are also going through financial difficulties right now, and wish them well.\nC: Offer a smaller amount you are comfortable losing, without calling it a loan.\nD: Tell them you will think about it and look into it, then avoid following up.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer uses the 'I also have difficulties' framing, which saves face for both parties, avoids direct accusation about past repayment, and closes the request without permanent damage to the relationship.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nc01_family_loan_decline.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"C-02: Recovering a Debt from a Friend\",\n    description=\"Tests face-saving logic and action sequencing in informal debt recovery. The social event must remain neutral. The follow-up framing positions the request as the lender's financial need, not the borrower's failure.\"\n)\ndef c02_debt_recovery(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA friend borrowed money from you eight months ago. They have not repaid it or mentioned it. You need the money back. You see them at a social event.\n \nQuestion: What is the most appropriate way to handle this?\n \nOptions:\nA: Bring it up directly at the event since you have seen them in person.\nB: Say nothing at the event. Send a formal written reminder afterwards.\nC: Greet them warmly at the event, say nothing about the debt there. Follow up privately afterwards, framing it gently as 'I have been trying to sort out my finances and wanted to check in about what we discussed.'\nD: Ask a mutual friend to mention it on your behalf to avoid direct confrontation.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"c\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be C.\",\n            \"The correct answer keeps the social event neutral, follows up privately, and uses framing that positions the request as the lender's financial need rather than the borrower's failure, preserving the friendship.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nc02_debt_recovery.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"C-03: Addressing Late Contributions in a Chama\",\n    description=\"Tests whether a model understands chama social dynamics. The chair must address a member's pattern privately, using a face-saving framing that presents the conversation as a general reminder rather than a personal accusation.\"\n)\ndef c03_chama_late_contributions(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA chama (savings group) member consistently contributes late. The group has a rule about this but nobody has raised it with her directly. You are the group chair.\n \nQuestion: What is the most appropriate way to address this?\n \nOptions:\nA: Send a general message to the entire group reminding all members about the contribution schedule rules.\nB: Check in with her privately, mention that you are reminding everyone about the schedule, and ask if everything is alright with her situation.\nC: Raise it at the next group meeting and ask members to vote on consequences for late contributions.\nD: Update the group rules formally and circulate a written policy to all members.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer combines a private conversation with a face-saving cover ('I am reminding everyone'), preserves the member's dignity, and checks on her wellbeing before addressing the rule.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nc03_chama_late_contributions.run(kbench.llm)\n \n \n# -------------------------------------------------------\n# DOMAIN D: GENDER ROLES\n# -------------------------------------------------------\n \n@kbench.task(\n    name=\"D-01: Senior Official at a Traditional Gathering\",\n    description=\"Tests whether a model understands that in a traditional rural Kenyan setting, family identity governs seating over professional rank. A senior official choosing the women's section is an act of social intelligence, not submission.\"\n)\ndef d01_official_seating(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nAt a mixed family gathering, men and women are seated separately in a traditional family home in a rural setting. A woman who is a senior government official arrives. The men's section has senior family elders. The women's section has her mother-in-law and other women.\n \nQuestion: Where does the official sit and what does this signal?\n \nOptions:\nA: She joins the men's section, given her seniority as a government official. This signals that her professional rank earns her a place among the decision-makers.\nB: She joins the women's section with her mother-in-law and the other women. This signals that she understands the context she has entered and that family identity governs here, not professional rank.\nC: She finds a neutral position between the two sections, signaling her dual role.\nD: She waits near the entrance for a senior family member to direct her to the appropriate seat.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"b\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be B.\",\n            \"The correct answer recognizes that in a traditional rural Kenyan setting, family identity governs social organization over professional status. Choosing the women's section is social intelligence, not submission.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nd01_official_seating.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"D-02: Husband Redirecting an Exclusionary Colleague\",\n    description=\"Tests whether a model understands fluid, face-saving inclusion techniques at a Kenyan workplace social event. The husband uses his social capital to redirect naturally, avoiding confrontation while correcting the exclusion.\"\n)\ndef d02_redirecting_colleague(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA husband and wife attend a social gathering at the husband's workplace. A senior male colleague begins directing all conversation exclusively to the husband, visibly ignoring the wife even when topics concern their home life.\n \nQuestion: What is the most appropriate response from the couple?\n \nOptions:\nA: The wife addresses the colleague directly to signal that she expects to be included in the conversation.\nB: The husband tells the colleague clearly that his wife should be part of the conversation.\nC: The husband naturally redirects by saying things like 'My wife would know better about that' when home topics arise, drawing her into the conversation without confronting the colleague.\nD: Both remain polite and the wife accepts the situation given the workplace context.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"c\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be C.\",\n            \"The correct answer uses the husband's social capital in the space to redirect naturally and include the wife without creating confrontation or causing the colleague to lose face.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nd02_redirecting_colleague.run(kbench.llm)\n \n \n@kbench.task(\n    name=\"D-03: Reading Silence After a Promotion Announcement\",\n    description=\"Tests whether a model can read silence as social information. After a significant promotion is announced among peers, a brief silence signals a real shift in group dynamics. The appropriate response manages that shift with grace rather than ignoring it.\"\n)\ndef d03_silence_after_promotion(llm) -> None:\n    prompt = \"\"\"You are being tested on social cognition in a Kenyan cultural context.\n \nScenario:\nA group of young women professionals, all in their thirties, are having lunch together. One mentions she has been offered a very significant promotion that would make her the most senior person in the room by far. The others go quiet briefly.\n \nQuestion: What does the silence most likely signal in this context, and what is the appropriate response from the woman who received the promotion?\n \nOptions:\nA: The silence signals discomfort or jealousy. She should immediately downplay the promotion to ease the tension.\nB: The silence is a normal pause. She should celebrate openly and enthusiastically since her friends should simply be happy for her.\nC: The silence is multivalent: it may hold admiration, recalibration, and some complexity. She should acknowledge the moment lightly with humor or humility, then actively pull the others back into the conversation.\nD: The silence is neutral. She should continue talking normally as if it did not happen.\n \nRespond with only the letter of the most appropriate answer: A, B, C, or D.\"\"\"\n \n    response: str = llm.prompt(prompt)\n \n    kbench.assertions.assert_in(\"c\", response.lower())\n \n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer selected must be C.\",\n            \"The correct answer reads the silence as carrying multiple meanings and responds with grace: a light acknowledgment followed by actively re-including the others in the conversation.\"\n        ]\n    )\n    for result in assessment.results:\n        kbench.assertions.assert_true(\n            result.passed,\n            expectation=f\"Judge criterion '{result.criterion}' failed: {result.reason}\"\n        )\n \nd03_silence_after_promotion.run(kbench.llm)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-16T04:02:19.183675Z","iopub.execute_input":"2026-04-16T04:02:19.184058Z","iopub.status.idle":"2026-04-16T04:06:08.617005Z","shell.execute_reply.started":"2026-04-16T04:02:19.184002Z","shell.execute_reply":"2026-04-16T04:06:08.615242Z"}},"outputs":[{"execution_count":13,"output_type":"execute_result","data":{"text/plain":"BokehModel(combine_events=True, render_bundle={'docs_json': {'7febd913-a199-487d-a306-1ba47a4deed9': {'version…","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"e69bf3deb483477ba06e9c4242e72566"}},"metadata":{}}],"execution_count":13}]}